{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Stores user information and their underwriting status.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "The unique Firebase Auth ID." },
        "displayName": { "type": "string", "description": "User's full name." },
        "email": { "type": "string", "format": "email", "description": "User's email address." },
        "photoURL": { "type": "string", "description": "URL to the user's profile picture." },
        "role": { "type": "string", "enum": ["user", "admin"], "description": "User's role in the system." },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the profile was created." },
        "updatedAt": { "type": "string", "format": "date-time", "description": "When the profile was last updated." }
      },
      "required": ["uid", "email", "role", "createdAt"]
    },
    "UnderwritingResult": {
      "title": "Underwriting Result",
      "description": "Stores the results of a talent underwriting diagnostic.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "The ID of the user who owns this result." },
        "aici": { "type": "number", "description": "AI Competence Index score." },
        "aioi": { "type": "number", "description": "AI Orchestrator Index score." },
        "aibs": { "type": "number", "description": "AI Builder Score." },
        "tier": { "type": "string", "description": "The calculated scoring tier." },
        "timestamp": { "type": "string", "format": "date-time", "description": "When the diagnostic was performed." }
      },
      "required": ["uid", "aici", "aioi", "aibs", "tier", "timestamp"]
    },
    "AccessRequest": {
      "title": "Access Request",
      "description": "Stores user requests for platform access.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "The ID of the user who made the request." },
        "tier": { "type": "string", "enum": ["institutional", "enterprise", "sovereign"], "description": "The requested access tier." },
        "name": { "type": "string", "description": "Full name of the requester." },
        "email": { "type": "string", "format": "email", "description": "Contact email." },
        "organization": { "type": "string", "description": "Affiliated organization." },
        "reason": { "type": "string", "description": "Reason for requesting access." },
        "status": { "type": "string", "enum": ["pending", "approved", "rejected"], "description": "Current status of the request." },
        "timestamp": { "type": "string", "format": "date-time", "description": "When the request was submitted." }
      },
      "required": ["tier", "name", "email", "reason", "status", "timestamp"]
    }
  },
  "firestore": {
    "/users/{uid}": {
      "schema": "UserProfile",
      "description": "Collection of user profile documents."
    },
    "/underwriting_results/{resultId}": {
      "schema": "UnderwritingResult",
      "description": "Collection of underwriting diagnostic results."
    },
    "/access_requests/{requestId}": {
      "schema": "AccessRequest",
      "description": "Collection of platform access requests."
    }
  }
}
